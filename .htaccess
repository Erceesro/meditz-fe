Deny from all
<IfModule mod_authz_core.c>
  <RequireAny>
    Require ip 109.183.230.59
    Require ip 85.163.43.74
    Require ip 185.5.69.7
  </RequireAny>
</IfModule>

<IfModule !mod_authz_core.c>
  Order Deny,Allow
  Deny from all
  Allow from 109.183.230.59
  Allow from 85.163.43.74
  Allow from 185.5.69.7
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
