# Apache 2.4+ config for meditz.rumici.cz static Angular build

# 1) Restrict access only to whitelisted IPs (edit this list)
<RequireAll>
    Require all denied

    # Local machine (keep/remove as needed)
    Require ip 109.183.230.59
    Require ip ::1

    # TODO: replace with your real public IPs/subnets
    # Require ip 203.0.113.10
    # Require ip 198.51.100.0/24
</RequireAll>

RewriteEngine On

# 2) Canonical host + HTTPS
RewriteCond %{HTTP_HOST} !^meditz\.rumici\.cz$ [NC,OR]
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://meditz.rumici.cz%{REQUEST_URI} [R=301,L]

# 3) Angular SPA fallback (serve index.html for non-file routes)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
RewriteRule ^ index.html [L]
